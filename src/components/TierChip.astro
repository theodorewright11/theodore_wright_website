---
type Tier = 'mine' | 'collab' | 'ai-led';
interface Props {
  tier: Tier;
}
const { tier } = Astro.props;

// 'mine' tier renders no chip — only the explicitly AI-assisted tiers are surfaced.
const labels: Partial<Record<Tier, string>> = {
  collab: 'me x ai',
  'ai-led': 'ai',
};
const label = labels[tier];
---

{label && (
  <span
    class="inline-block font-mono text-[10px] uppercase text-muted border border-rule rounded-sm px-1.5 py-px whitespace-nowrap"
    style="letter-spacing: 0.08em"
  >
    {label}
  </span>
)}
