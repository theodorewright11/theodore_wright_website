---
interface LogEntry {
  pass: number;
  date: string;
  passes: string[];
  why: string;
  changes: string[];
}
interface Props {
  log: LogEntry[];
}
const { log } = Astro.props;
const reversed = [...log].reverse();
---

<aside class="mt-14 pt-7 border-t border-rule not-prose">
  <h2 class="font-mono text-[10px] font-medium uppercase text-muted mb-6"
      style="letter-spacing: 0.18em">Iteration history</h2>
  <ol class="space-y-7 list-none p-0">
    {reversed.map(entry => (
      <li>
        <div class="flex items-baseline justify-between mb-2">
          <span class="font-mono text-[11px] text-ink">Pass {entry.pass}</span>
          <span class="font-mono text-[11px] text-muted">{entry.date}</span>
        </div>
        <div class="flex flex-wrap gap-1.5 mb-3">
          {entry.passes.map(p => (
            <span class="font-mono text-[10px] uppercase border border-rule rounded-sm px-1.5 py-px text-muted"
                  style="letter-spacing: 0.08em">{p}</span>
          ))}
        </div>
        <p class="font-serif text-[15px] text-ink-soft leading-[1.55] mb-2">
          <span class="font-mono text-[10px] uppercase text-muted mr-2"
                style="letter-spacing: 0.08em">Why</span>
          {entry.why}
        </p>
        <ul class="font-serif text-[15px] text-ink-soft leading-[1.55] list-disc pl-5 space-y-1 m-0">
          {entry.changes.map(c => <li>{c}</li>)}
        </ul>
      </li>
    ))}
  </ol>
</aside>
