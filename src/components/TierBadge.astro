---
type Tier = 'mine' | 'collab' | 'ai-led';
interface Props {
  tier: Tier;
}
const { tier } = Astro.props;

const labels: Record<Tier, { text: string; class: string }> = {
  mine: { text: 'Me', class: 'bg-primary-100 text-primary-800' },
  collab: { text: 'Me + AI', class: 'bg-gray-200 text-gray-700' },
  'ai-led': { text: 'AI', class: 'bg-gray-100 text-gray-500' },
};
const { text, class: cls } = labels[tier] ?? labels.mine;
---

<span class:list={['inline-block text-xs font-medium px-2 py-0.5 rounded uppercase tracking-wider', cls]}>
  {text}
</span>
