---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TierChip from '../../components/TierChip.astro';
import { getCollection } from 'astro:content';
import bio from '../../data/bio.json';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const fmt = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<BaseLayout title={`${entry.data.title} — Writing`} description={entry.data.description}>
  <article class="max-w-[640px] mx-auto px-8 pt-14 pb-24">
    <a href="/writing"
       class="font-mono text-[11px] uppercase text-muted no-underline hover:text-accent transition-colors"
       style="letter-spacing: 0.08em">← Writing</a>

    <header class="mt-5 mb-10 pb-8 border-b border-rule">
      <div class="flex items-baseline gap-3 mb-4 flex-wrap">
        <span class="font-mono text-[11px] text-muted">{fmt(entry.data.date)}</span>
        <TierChip tier={entry.data.tier} />
        {entry.data.tags.map(tag => (
          <span class="font-mono text-[10px] text-muted" style="letter-spacing: 0.06em">#{tag}</span>
        ))}
      </div>
      <h1 class="font-display font-semibold text-[42px] leading-[1.08] m-0 text-ink"
          style="letter-spacing: -0.025em; text-wrap: balance">{entry.data.title}</h1>
    </header>

    <div class="essay-prose">
      <Content />
    </div>

    <hr class="border-0 border-t border-rule mt-14 mb-8" />
    <p class="font-serif italic text-[14px] text-muted m-0">
      Written by Teddy. Comments welcome at
      <a href={`mailto:${bio.email}`} class="text-accent">{bio.email}</a>.
    </p>
  </article>
</BaseLayout>
