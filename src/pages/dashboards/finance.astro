---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FinanceDashboard from '../../components/dashboards/finance/FinanceDashboard';
---

<BaseLayout
  title="Finance — Dashboards"
  description="A personal finance dashboard. Public demo: your data lives in your browser, with CSV import/export."
>
  <section class="max-w-[1080px] mx-auto px-8 pt-10 pb-24">
    <div class="flex items-center justify-between gap-4 flex-wrap mb-3">
      <a href="/dashboards"
         class="font-mono text-[11px] uppercase text-muted no-underline hover:text-accent transition-colors"
         style="letter-spacing: 0.08em">← Dashboards</a>
      <span class="font-mono text-[10px] uppercase text-muted border border-rule rounded-sm px-2 py-px"
            style="letter-spacing: 0.12em">Private · v1</span>
    </div>

    <h1 class="font-display font-semibold text-[36px] leading-[1.08] m-0 mb-2 text-ink"
        style="letter-spacing: -0.025em; text-wrap: balance">Finance</h1>
    <p class="font-serif text-[15px] text-muted leading-[1.55] m-0 mb-8 max-w-[640px]"
       style="text-wrap: pretty">
      Log spending, set budgets, see where the money's actually going. Data lives in this browser's
      localStorage for now; Google Sheets sync is the next step.
    </p>

    <FinanceDashboard client:only="react" />
  </section>
</BaseLayout>
