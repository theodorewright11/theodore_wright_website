---
import BaseLayout from '../../layouts/BaseLayout.astro';

const planned = [
  {
    slug: 'decision-tracker',
    title: 'Decision Tracker',
    description: 'Confidence × stakes × reversibility × disclosure × fit. Run a decision through the framework and see where it breaks.',
  },
  {
    slug: 'finance',
    title: 'Finance',
    description: 'Personal finance dashboard. Public demo lets you plug in your own numbers; private version pulls my data.',
  },
  {
    slug: 'emotional-wellbeing',
    title: 'Emotional Well-being',
    description: 'Track mood, regulation cost, and recovery — informed by the social-output-efficiency model.',
  },
  {
    slug: 'social-environment',
    title: 'Social Environment',
    description: 'Score the six social-environment subscales and project the maintenance/output split.',
  },
];
---

<BaseLayout title="Dashboards — Teddy Wright" description="Interactive dashboards for decision-making, finance, well-being, and social environment.">
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-16">
    <h1 class="text-3xl font-bold tracking-tight mb-4">Dashboards</h1>
    <p class="text-gray-500 mb-4">
      Interactive dashboards for personal models. Each will ship in two tiers:
      a public demo (use it on your own data, stays in your browser, CSV import/export)
      and a private version with my own data (auth-gated).
    </p>
    <p class="text-gray-500 mb-12">
      None are live yet. Planned:
    </p>

    <div class="space-y-6">
      {planned.map(d => (
        <article class="border-l-2 border-gray-200 pl-4">
          <span class="text-xs font-medium uppercase tracking-wider text-gray-400">Planned</span>
          <h2 class="text-lg font-semibold mt-1 text-gray-700">{d.title}</h2>
          <p class="text-sm text-gray-500 mt-2">{d.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
