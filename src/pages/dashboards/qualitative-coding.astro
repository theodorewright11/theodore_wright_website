---
import '../../styles/global.css';
import QualitativeCodingDashboard from '../../components/dashboards/qualitative-coding/QualitativeCodingDashboard';

const title = 'Qualitative Coding — Dashboards';
const description = 'Code text documents with a nested code tree. Exports JSON + Markdown for AI-comparison work.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />
    <title>{title}</title>
    <style is:global>
      html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        background: #ffffff;
        color: #0f172a;
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      body {
        overflow: hidden;
      }
      #qc-root {
        height: 100vh;
        width: 100vw;
      }
      .md-preview h1 { font-size: 24px; font-weight: 700; margin: 0.4em 0 0.3em; letter-spacing: -0.02em; color: #0f172a; }
      .md-preview h2 { font-size: 19px; font-weight: 700; margin: 0.6em 0 0.3em; color: #0f172a; }
      .md-preview h3 { font-size: 16px; font-weight: 700; margin: 0.6em 0 0.2em; color: #1e293b; }
      .md-preview h4, .md-preview h5, .md-preview h6 { font-size: 14px; font-weight: 700; margin: 0.6em 0 0.2em; color: #1e293b; }
      .md-preview p { margin: 0 0 0.7em; line-height: 1.65; }
      .md-preview p:last-child { margin-bottom: 0; }
      .md-preview ul, .md-preview ol { margin: 0.2em 0 0.7em; padding-left: 1.4em; line-height: 1.55; }
      .md-preview li { margin: 0.15em 0; }
      .md-preview ul { list-style: disc; }
      .md-preview ol { list-style: decimal; }
      .md-preview strong { font-weight: 700; color: #0f172a; }
      .md-preview em { font-style: italic; }
      .md-preview code { background: #f1f5f9; color: #1e293b; padding: 0.1em 0.35em; border-radius: 3px; font-family: ui-monospace, "JetBrains Mono", monospace; font-size: 0.92em; }
      .md-preview pre { background: #0f172a; color: #f1f5f9; padding: 0.8em 1em; border-radius: 8px; overflow-x: auto; margin: 0.6em 0; font-size: 13px; }
      .md-preview pre code { background: transparent; color: inherit; padding: 0; }
      .md-preview a { color: #2563eb; text-decoration: underline; }
      .md-preview a:hover { color: #1d4ed8; }
      .md-preview blockquote { border-left: 3px solid #cbd5e1; padding-left: 0.8em; color: #475569; margin: 0.4em 0 0.7em; font-style: italic; }
    </style>
  </head>
  <body>
    <div id="qc-root">
      <QualitativeCodingDashboard client:only="react" />
    </div>
  </body>
</html>
