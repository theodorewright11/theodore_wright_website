---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('updates', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Updates — Teddy Wright" description="Weekly notes on what I'm working on — research, reading, ideas in progress.">
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-16">
    <h1 class="text-3xl font-bold tracking-tight mb-4">Updates</h1>
    <p class="text-gray-500 mb-12">
      Weekly notes on what I've been working on — research progress, reading, ideas in progress. Mostly for my own reference; partly so anyone curious can see what's moving.
    </p>

    {items.length === 0 ? (
      <div class="text-center py-16 text-gray-400">
        <p class="text-sm">No updates yet.</p>
      </div>
    ) : (
      <div class="space-y-8">
        {items.map(({ slug, data }) => (
          <article class="border-l-2 border-primary-200 pl-4">
            <div class="flex items-baseline gap-3 mb-1">
              <time class="text-xs text-gray-400 font-mono">
                {data.date.toISOString().slice(0, 10)}
              </time>
              <span class="text-xs uppercase tracking-wider text-gray-400">{data.period}</span>
            </div>
            <h2 class="text-lg font-semibold mt-1">
              <a href={`/updates/${slug}`} class="hover:text-primary-600 transition-colors">
                {data.title}
              </a>
            </h2>
            {data.description && <p class="text-sm text-gray-500 mt-2">{data.description}</p>}
            {data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-3">
                {data.tags.map(tag => (
                  <span class="text-xs text-gray-400">#{tag}</span>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
