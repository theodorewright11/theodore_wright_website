---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Updates — Teddy Wright"
  description="Weekly updates on what's moving — research, reading, ideas in progress.">
  <section class="max-w-[760px] mx-auto px-8 pt-14 pb-24">
    <h1 class="font-display font-semibold text-[48px] leading-none m-0 mb-3 text-ink"
        style="letter-spacing: -0.03em">Updates</h1>
    <p class="font-serif text-[17px] text-ink-soft leading-[1.55] max-w-[580px] m-0 mb-4">
      Coming soon.
    </p>
    <p class="font-serif text-[15px] text-muted leading-[1.55] max-w-[580px] m-0">
      Weekly updates — mostly for me, to keep track of my research and what I'm working on; partly for anyone curious to see what's moving.
    </p>
  </section>
</BaseLayout>
