---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('updates');
  return items.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const fmt = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<BaseLayout title={`${entry.data.title} — Updates`} description={entry.data.description}>
  <article class="max-w-[760px] mx-auto px-8 pt-14 pb-24">
    <a href="/updates"
       class="font-mono text-[11px] uppercase text-muted no-underline hover:text-accent transition-colors"
       style="letter-spacing: 0.08em">← Updates</a>

    <header class="mt-5 mb-10 pb-8 border-b border-rule">
      <div class="flex items-baseline gap-3 mb-3 flex-wrap">
        <span class="font-mono text-[11px] text-muted">{fmt(entry.data.date)}</span>
        <span class="font-mono text-[10px] uppercase text-accent"
              style="letter-spacing: 0.12em">{entry.data.period}</span>
      </div>
      <h1 class="font-display font-semibold text-[36px] leading-[1.1] m-0 mb-3 text-ink"
          style="letter-spacing: -0.02em; text-wrap: balance">{entry.data.title}</h1>
      {entry.data.description && (
        <p class="font-serif text-[17px] text-ink-soft leading-[1.55] m-0"
           style="text-wrap: pretty">{entry.data.description}</p>
      )}
    </header>

    <div class="paper-prose">
      <Content />
    </div>
  </article>
</BaseLayout>
