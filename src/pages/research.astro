---
import BaseLayout from '../layouts/BaseLayout.astro';
import GroupHeader from '../components/GroupHeader.astro';
import DownloadMd from '../components/DownloadMd.astro';
import { getCollection } from 'astro:content';

const order: Array<['in-progress' | 'published' | 'upcoming' | 'contribution', string]> = [
  ['in-progress', 'In Progress'],
  ['published', 'Finished'],
  ['upcoming', 'Upcoming'],
  ['contribution', 'Contributions'],
];

const all = await getCollection('research');

const groups = order
  .map(([k, l]) => ({
    k,
    l,
    items: all
      .filter(r => r.data.status === k)
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
  }))
  .filter(g => g.items.length > 0);

const yearOf = (d: Date) => String(d.getFullYear());
---

<BaseLayout title="My Research — Teddy Wright">
  <section class="max-w-[760px] mx-auto px-8 pt-14 pb-24">
    <h1 class="font-display font-semibold text-[48px] leading-none m-0 mb-3 text-ink"
        style="letter-spacing: -0.03em">My Research</h1>
    <p class="font-serif text-[17px] text-muted leading-[1.55] max-w-[580px] m-0 mb-14">
      So far generally in the HCI space of AI — specifically how AI impacts the labor market, and how people’s perceptions of AI can diverge from reality.
    </p>

    <DownloadMd href="/research.md" label="download all research (.md)" />

    {groups.map(g => (
      <section class="mb-14">
        <GroupHeader label={g.l} count={g.items.length} />
        {g.items.map((r, i) => (
          <article class:list={[
            'py-5',
            i < g.items.length - 1 ? 'border-b border-rule-soft' : '',
          ]}>
            <div class="flex items-baseline gap-3 mb-1.5 flex-wrap">
              <h3 class="font-display font-semibold text-[22px] m-0 text-ink flex-1"
                  style="letter-spacing: -0.015em">
                <a href={`/research/${r.slug}`}
                   class="text-ink no-underline hover:text-accent transition-colors">
                  {r.data.title}
                </a>
              </h3>
              <span class="font-mono text-[11px] text-muted">{yearOf(r.data.date)}</span>
            </div>
            <p class="font-serif text-[15px] text-ink-soft leading-[1.55] m-0 mb-2"
               style="text-wrap: pretty">{r.data.description}</p>
            {([r.data.collaborators?.length, r.data.venue].some(Boolean)) && (
              <div class="font-mono text-[11px] text-muted" style="letter-spacing: 0.04em">
                {[
                  r.data.collaborators?.length ? `with ${r.data.collaborators.join(' & ')}` : null,
                  r.data.venue ?? null,
                ].filter(Boolean).join(' · ')}
              </div>
            )}
            {(r.data.paperUrl || r.data.externalUrl) && (
              <div class="mt-3 flex gap-3 flex-wrap font-mono text-[13px] font-semibold uppercase"
                   style="letter-spacing: 0.1em">
                {r.data.paperUrl && (
                  <a href={r.data.paperUrl} target="_blank" rel="noopener"
                     class="inline-block px-3 py-1.5 border border-accent text-accent no-underline hover:bg-accent hover:text-paper transition-colors">
                    Read the paper →
                  </a>
                )}
                {r.data.externalUrl && (
                  <a href={r.data.externalUrl} target="_blank" rel="noopener"
                     class="inline-block px-3 py-1.5 border border-rule text-ink-soft no-underline hover:border-accent hover:text-accent transition-colors">
                    External ↗
                  </a>
                )}
              </div>
            )}
          </article>
        ))}
      </section>
    ))}
  </section>
</BaseLayout>
