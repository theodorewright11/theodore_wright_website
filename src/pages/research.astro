---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const order: Array<['in-progress' | 'published' | 'upcoming' | 'contribution', string]> = [
  ['in-progress', 'In Progress'],
  ['published', 'Finished'],
  ['upcoming', 'Upcoming'],
  ['contribution', 'Contributions'],
];

const all = await getCollection('research');

const groups = order
  .map(([k, l]) => ({
    k,
    l,
    items: all
      .filter(r => r.data.status === k)
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
  }))
  .filter(g => g.items.length > 0);

const yearOf = (d: Date) => String(d.getFullYear());
---

<BaseLayout title="Research — Teddy Wright">
  <section class="max-w-[760px] mx-auto px-8 pt-14 pb-24">
    <h1 class="font-display font-semibold text-[48px] leading-none m-0 mb-3 text-ink"
        style="letter-spacing: -0.03em">Research</h1>
    <p class="font-serif text-[17px] text-muted leading-[1.55] max-w-[580px] m-0 mb-14">
      AI’s impact on labor markets, human information processing, and tools for AI policy.
    </p>

    {groups.map((g, gi) => (
      <section class="mb-14">
        <div class="flex items-baseline gap-3 mb-6 pb-2 border-b border-rule">
          <span class="font-mono text-[11px] text-accent" style="letter-spacing: 0.16em">§ {gi + 1}</span>
          <h2 class="font-display font-semibold text-[18px] text-ink m-0"
              style="letter-spacing: -0.01em">{g.l}</h2>
          <span class="font-mono text-[11px] text-muted ml-auto">{g.items.length}</span>
        </div>
        {g.items.map((r, i) => (
          <article class:list={[
            'py-5',
            i < g.items.length - 1 ? 'border-b border-rule-soft' : '',
          ]}>
            <div class="flex items-baseline gap-3 mb-1.5 flex-wrap">
              <h3 class="font-display font-semibold text-[22px] m-0 text-ink flex-1"
                  style="letter-spacing: -0.015em">
                <a href={`/research/${r.slug}`}
                   class="text-ink no-underline hover:text-accent transition-colors">
                  {r.data.title}
                </a>
              </h3>
              <span class="font-mono text-[11px] text-muted">{yearOf(r.data.date)}</span>
            </div>
            <p class="font-serif text-[15px] text-ink-soft leading-[1.55] m-0 mb-2"
               style="text-wrap: pretty">{r.data.description}</p>
            <div class="font-mono text-[11px] text-muted" style="letter-spacing: 0.04em">
              {[
                r.data.collaborators?.length ? `with ${r.data.collaborators.join(' & ')}` : null,
                r.data.venue ?? null,
              ].filter(Boolean).join(' · ')}
              {r.data.paperUrl && (
                <>
                  {(r.data.collaborators?.length || r.data.venue) ? ' · ' : ''}
                  <a href={r.data.paperUrl} target="_blank" rel="noopener"
                     class="text-accent no-underline hover:underline">open paper →</a>
                </>
              )}
              {r.data.externalUrl && (
                <>
                  {(r.data.collaborators?.length || r.data.venue || r.data.paperUrl) ? ' · ' : ''}
                  <a href={r.data.externalUrl} target="_blank" rel="noopener"
                     class="text-accent no-underline hover:underline">external ↗</a>
                </>
              )}
            </div>
          </article>
        ))}
      </section>
    ))}
  </section>
</BaseLayout>
