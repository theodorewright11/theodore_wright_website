---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const statusLabel: Record<string, string> = {
  'in-progress': 'In Progress',
  'published': 'Finished',
  'upcoming': 'Upcoming',
  'contribution': 'Contributions',
};

const sectionOrder = ['in-progress', 'published', 'upcoming', 'contribution'];

const all = await getCollection('research');

const sections = sectionOrder
  .map(status => ({
    status,
    label: statusLabel[status],
    items: all
      .filter(entry => entry.data.status === status)
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
  }))
  .filter(section => section.items.length > 0);

const meta = (collaborators: string[], venue?: string) => {
  const parts: string[] = [];
  if (collaborators.length > 0) parts.push(`With ${collaborators.join(' & ')}`);
  if (venue) parts.push(venue);
  return parts.join(' · ');
};
---

<BaseLayout title="Research — Teddy Wright">
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-16">
    <h1 class="text-3xl font-bold tracking-tight mb-4">Research</h1>
    <p class="text-gray-500 mb-12">
      AI's impact on labor markets, human information processing, and tools for AI policy.
    </p>

    <div class="space-y-16">
      {sections.map(section => {
        const accent = section.status === 'in-progress' || section.status === 'published';
        return (
          <div>
            <h2 class:list={[
              'text-sm font-semibold uppercase tracking-wider mb-6',
              accent ? 'text-primary-600' : 'text-gray-400',
            ]}>
              {section.label}
            </h2>
            <div class="space-y-8">
              {section.items.map(({ slug, data }) => {
                const m = meta(data.collaborators, data.venue);
                return (
                  <article class:list={['border-l-2 pl-5', accent ? 'border-primary-200' : 'border-gray-200']}>
                    <h3 class="text-lg font-semibold">
                      <a href={`/research/${slug}`} class="hover:text-primary-600 transition-colors">
                        {data.title}
                      </a>
                    </h3>
                    <p class="text-sm text-gray-500 mt-2">{data.description}</p>
                    {m && <p class="text-xs text-gray-400 mt-2">{m}</p>}
                  </article>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>
