---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import StatusPill from '../components/StatusPill.astro';
import TierChip from '../components/TierChip.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import bio from '../data/bio.json';
import dashboards from '../data/dashboards.json';
import plannedAi from '../data/ai_research_planned.json';
import meImg from '../assets/pic_of_me.png';

const fmt = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const writing = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const research = (await getCollection('research'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const models = (await getCollection('models')).sort((a, b) => {
  const livedDelta = Number(b.data.status === 'published') - Number(a.data.status === 'published');
  if (livedDelta !== 0) return livedDelta;
  const featuredDelta = Number(b.data.featured) - Number(a.data.featured);
  if (featuredDelta !== 0) return featuredDelta;
  return b.data.date.valueOf() - a.data.date.valueOf();
});

// AI's Research topics — group MDX entries by topic folder
const aiAll = await getCollection('ai_research');
const stageOrder = ['lit-review', 'topology', 'model', 'data', 'build', 'writeup'] as const;
type StageEntry = { id: string; status: string };
const topicMap = new Map<
  string,
  { overview: typeof aiAll[number] | null; stages: StageEntry[] }
>();
for (const entry of aiAll) {
  const [topic, stage] = entry.slug.split('/');
  if (!topic) continue;
  if (!topicMap.has(topic)) topicMap.set(topic, { overview: null, stages: [] });
  if (stage === 'overview') {
    topicMap.get(topic)!.overview = entry;
  } else if (stage) {
    topicMap.get(topic)!.stages.push({ id: stage, status: entry.data.status });
  }
}
const aiTopics = Array.from(topicMap.entries()).map(([slug, t]) => {
  const stages = stageOrder.map(id => t.stages.find(s => s.id === id) ?? { id, status: 'planned' });
  const active = stages.some(s => s.status === 'in-progress' || s.status === 'complete');
  return { slug, title: t.overview?.data.title ?? slug, active };
});

// Show 3 planned topics on the home column.
const homePlannedAi = plannedAi.slice(0, 3);

const featured = writing[0];

const researchStatusLabel = (status: string) =>
  status === 'in-progress' ? 'in progress'
  : status === 'published' ? 'finished'
  : status === 'upcoming' ? 'upcoming'
  : 'contribution';
const researchStatusTone = (status: string): 'live' | 'planned' | 'soft' =>
  status === 'in-progress' ? 'live'
  : status === 'published' ? 'soft'
  : status === 'contribution' ? 'soft'
  : 'planned';
---

<BaseLayout title="Teddy Wright">
  <div class="max-w-[1080px] mx-auto px-8 pt-12 pb-20">

    {/* Masthead — name above, photo + credentials side-by-side below */}
    <div class="border-b-4 border-double border-ink pb-8 mb-9">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
        <div>
          <h1 class="font-display font-semibold text-[60px] sm:text-[76px] text-ink leading-[0.92] m-0 whitespace-nowrap"
              style="letter-spacing: -0.035em">
            Teddy Wright
          </h1>
          <div class="flex items-center gap-5 mt-5">
            <Image src={meImg} alt="Teddy Wright"
                   width={224} height={224} densities={[1, 2]} format="webp" quality={82}
                   class="w-24 h-24 sm:w-28 sm:h-28 object-cover border border-rule rounded-sm flex-shrink-0" />
            <p class="font-serif italic text-[13px] text-muted leading-[1.55] m-0"
               style="text-wrap: pretty">{bio.credentials}</p>
          </div>
        </div>
        <div>
          <p class="font-serif text-base leading-[1.6] text-ink-soft m-0 mb-3"
             style="text-wrap: pretty">{bio.blurb}</p>
          <div class="font-mono text-[11px] uppercase text-muted"
               style="letter-spacing: 0.08em">
            <a href={bio.linkedin} target="_blank" rel="noopener" class="text-ink no-underline hover:text-accent transition-colors">linkedin</a>
            <span class="text-muted"> / </span>
            <a href={bio.github} target="_blank" rel="noopener" class="text-ink no-underline hover:text-accent transition-colors">github</a>
            <span class="text-muted"> / </span>
            <a href={bio.substack} target="_blank" rel="noopener" class="text-ink no-underline hover:text-accent transition-colors">substack</a>
            <span class="text-muted"> / </span>
            <a href={`mailto:${bio.email}`} class="text-ink no-underline hover:text-accent transition-colors">email</a>
          </div>
        </div>
      </div>
    </div>

    {/* Three-column index */}
    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,2fr)_minmax(0,1.3fr)_minmax(0,1.1fr)] gap-12 items-start">

      {/* Column 1 — Writing + My Research */}
      <div>
        <SectionLabel label="Writing" href="/writing" />
        {featured && (
          <article class="mb-7">
            <div class="flex gap-2 mb-2.5 items-center flex-wrap">
              <span class="font-mono text-[10px] text-muted" style="letter-spacing: 0.1em">
                {fmt(featured.data.date)}
              </span>
              <TierChip tier={featured.data.tier} />
            </div>
            <h3 class="font-display font-semibold text-[30px] leading-[1.05] m-0 mb-3 text-ink"
                style="letter-spacing: -0.02em; text-wrap: balance">
              <a href={`/writing/${featured.slug}`}
                 class="text-ink no-underline hover:underline">
                {featured.data.title}
              </a>
            </h3>
            <p class="font-serif text-[15px] leading-[1.55] text-ink-soft m-0"
               style="text-wrap: pretty">
              {featured.data.description}
            </p>
            <a href={`/writing/${featured.slug}`}
               class="inline-block mt-3 font-mono text-[13px] font-semibold uppercase text-accent no-underline hover:underline"
               style="letter-spacing: 0.14em">
              Continue reading →
            </a>
          </article>
        )}

        <div class="mt-9">
          <SectionLabel label="My Research" href="/research" />
          {research.slice(0, 5).map(r => (
            <article class="py-2.5">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <StatusPill label={researchStatusLabel(r.data.status)} tone={researchStatusTone(r.data.status)} />
                {r.data.venue && (
                  <span class="font-mono text-[10px] uppercase text-muted"
                        style="letter-spacing: 0.08em">{r.data.venue}</span>
                )}
              </div>
              <h4 class="font-serif text-[15px] font-semibold m-0 mb-[3px] text-ink leading-[1.3]">
                <a href={`/research/${r.slug}`}
                   class="text-ink no-underline hover:text-accent transition-colors">
                  {r.data.title}
                </a>
              </h4>
              {(r.data.paperUrl || r.data.externalUrl) && (
                <div class="mt-1.5 flex gap-3 font-mono text-[12px] font-semibold uppercase"
                     style="letter-spacing: 0.1em">
                  {r.data.paperUrl && (
                    <a href={r.data.paperUrl} target="_blank" rel="noopener"
                       class="text-accent no-underline hover:underline">read paper →</a>
                  )}
                  {r.data.externalUrl && (
                    <a href={r.data.externalUrl} target="_blank" rel="noopener"
                       class="text-accent no-underline hover:underline">external ↗</a>
                  )}
                </div>
              )}
            </article>
          ))}
        </div>
      </div>

      {/* Column 2 — AI's Research + Models */}
      <div>
        <SectionLabel label="AI’s Research" href="/ai-research" />
        {aiTopics.map(t => (
          <article class="mb-3">
            <div class="mb-1">
              <StatusPill label={t.active ? 'in progress' : 'planned'}
                          tone={t.active ? 'live' : 'planned'} />
            </div>
            <h3 class="font-serif font-semibold text-[15px] leading-[1.3] m-0 text-ink">
              <a href={`/ai-research/${t.slug}`}
                 class="text-ink no-underline hover:text-accent transition-colors">
                {t.title}
              </a>
            </h3>
          </article>
        ))}
        {homePlannedAi.map(t => (
          <article class="mb-3 opacity-80">
            <div class="mb-1">
              <StatusPill label="planned" tone="planned" />
            </div>
            <h3 class="font-serif font-semibold text-[15px] leading-[1.3] m-0 text-ink-soft">
              {t.title}
            </h3>
          </article>
        ))}

        <div class="mt-8">
          <SectionLabel label="Models" href="/models" />
          {models.map(m => {
            const live = m.data.status === 'published';
            return (
              <article class="mb-3">
                <div class="mb-1">
                  <StatusPill label={live ? 'in progress' : 'planned'}
                              tone={live ? 'live' : 'planned'} />
                </div>
                <h3 class:list={[
                  'font-serif font-semibold text-[15px] leading-[1.3] m-0',
                  live ? 'text-ink' : 'text-ink-soft',
                ]}>
                  {live ? (
                    <a href={`/models/${m.slug}`}
                       class="text-ink no-underline hover:text-accent transition-colors">
                      {m.data.title}
                    </a>
                  ) : (
                    m.data.title
                  )}
                </h3>
              </article>
            );
          })}
        </div>
      </div>

      {/* Column 3 — Dashboards + Updates (matches nav order) */}
      <div>
        <SectionLabel label="Dashboards" href="/dashboards" />
        {dashboards.map(d => {
          const live = d.status !== 'planned';
          return (
            <article class="mb-3">
              <div class="mb-1">
                <StatusPill label={d.status.replace('-', ' ')}
                            tone={live ? 'live' : 'planned'} />
              </div>
              <h3 class:list={[
                'font-serif font-semibold text-[15px] leading-[1.3] m-0',
                live ? 'text-ink' : 'text-ink-soft',
              ]}>{d.title}</h3>
            </article>
          );
        })}

        <div class="mt-8">
          <SectionLabel label="Updates" href="/updates" />
          <div class="font-serif italic text-[13px] text-muted leading-[1.55]"
               style="text-wrap: pretty">
            Coming soon. Weekly updates — partly for me, to keep track of my research and what I'm working on. Partly for anyone in my life, or anyone curious in general, who might want to see what I'm working on.
          </div>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>
