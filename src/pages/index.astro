---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Teddy Wright">
  <section class="max-w-3xl mx-auto px-6 pt-20 pb-16">
    <h1 class="text-4xl font-bold tracking-tight mb-4">
      Teddy Wright
    </h1>
    <p class="text-xl text-gray-500 leading-relaxed mb-8">
      CS &amp; AI researcher exploring how artificial intelligence reshapes labor markets,
      information processing, and human decision-making. Currently building tools at
      Utah's Office of AI Policy.
    </p>
    <div class="flex gap-4 mb-16">
      <a href="/research" class="text-sm font-medium text-primary-600 hover:text-primary-800 transition-colors">
        Research &rarr;
      </a>
      <a href="/writing" class="text-sm font-medium text-primary-600 hover:text-primary-800 transition-colors">
        Writing &rarr;
      </a>
      <a href="/about" class="text-sm font-medium text-primary-600 hover:text-primary-800 transition-colors">
        About &rarr;
      </a>
    </div>

    <section class="mb-16">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-6">Current Work</h2>
      <div class="space-y-6">
        <div class="border-l-2 border-primary-200 pl-4">
          <h3 class="font-medium">AI Labor Market Dashboard</h3>
          <p class="text-sm text-gray-500 mt-1">
            Interactive visualization of LLM impact across 800+ occupations.
            FastAPI + Next.js, mapping agentic AI capabilities onto 17,000+ ONET tasks.
          </p>
          <span class="text-xs text-gray-400">Utah Office of AI Policy</span>
        </div>
        <div class="border-l-2 border-primary-200 pl-4">
          <h3 class="font-medium">AI Miscalibration Research</h3>
          <p class="text-sm text-gray-500 mt-1">
            "Why Are People Miscalibrated on AI?" — framework decomposing
            view formation into optimization targets, information quality, and processing quality.
          </p>
          <span class="text-xs text-gray-400">With Valen Cole · AI + Ethics Workshop 2026</span>
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
