---
import BaseLayout from '../layouts/BaseLayout.astro';
import TierChip from '../components/TierChip.astro';
import DownloadMd from '../components/DownloadMd.astro';
import { getCollection } from 'astro:content';
import bio from '../data/bio.json';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<BaseLayout title="Writing — Teddy Wright" description="Essays on AI, identity, information processing.">
  <section class="max-w-[760px] mx-auto px-8 pt-14 pb-24">
    <h1 class="font-display font-semibold text-[48px] leading-none m-0 mb-3 text-ink"
        style="letter-spacing: -0.03em">Writing</h1>
    <p class="font-serif text-[17px] text-muted leading-[1.55] max-w-[580px] m-0 mb-14">
      Essays on whatever's caught my attention — usually somewhere in the orbit of evolutionary biology, game theory, philosophy, AI, and the strange shape modern life has taken. Also on <a href={bio.substack} target="_blank" rel="noopener" class="text-accent hover:underline">Substack</a>.
    </p>

    <DownloadMd href="/writing.md" label="download all writing (.md)" />

    {posts.length === 0 ? (
      <div class="text-center py-16 font-serif italic text-muted">
        <p>Posts coming soon.</p>
      </div>
    ) : (
      <div>
        {posts.map((p, i) => (
          <article class:list={[
            'py-7 border-t border-rule',
            i === posts.length - 1 ? 'border-b border-rule' : '',
          ]}>
            <div class="flex items-baseline gap-3 mb-2.5 flex-wrap">
              <span class="font-mono text-[11px] text-muted">{fmt(p.data.date)}</span>
              <TierChip tier={p.data.tier} />
            </div>
            <h2 class="font-display font-semibold text-[28px] leading-[1.1] m-0 mb-3 text-ink"
                style="letter-spacing: -0.02em; text-wrap: balance">
              <a href={`/writing/${p.slug}`}
                 class="text-ink no-underline hover:text-accent transition-colors">
                {p.data.title}
              </a>
            </h2>
            <p class="font-serif text-[16px] text-ink-soft leading-[1.6] m-0"
               style="text-wrap: pretty">{p.data.description}</p>
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
