---
import BaseLayout from '../layouts/BaseLayout.astro';

// This will eventually pull from content/blog/*.mdx files
// For now, placeholder structure
---

<BaseLayout title="Writing — Teddy Wright">
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-16">
    <h1 class="text-3xl font-bold tracking-tight mb-4">Writing</h1>
    <p class="text-gray-500 mb-12">
      Essays on AI, identity, information processing, and rebuilding worldviews from
      first principles. Also on
      <a href="https://substack.com/@theodorewright" class="text-primary-600 hover:text-primary-800" target="_blank" rel="noopener">Substack</a>.
    </p>

    <div class="text-center py-16 text-gray-400">
      <p class="text-sm">Posts coming soon.</p>
    </div>
  </section>
</BaseLayout>
