---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GroupHeader from '../../components/GroupHeader.astro';
import DownloadMd from '../../components/DownloadMd.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('ai_research');

const stageOrder = ['lit-review', 'topology', 'model', 'data', 'build', 'writeup'] as const;
const stageLabel: Record<string, string> = {
  'lit-review': 'lit review',
  topology: 'topology',
  model: 'model',
  data: 'data',
  build: 'build',
  writeup: 'writeup',
};

type Stage = { id: string; label: string; status: string };
type ActiveTopic = {
  slug: string;
  title: string;
  desc: string;
  stages: Stage[];
  done: number;
  active: boolean;
  latestDate: number;
};

const topicMap = new Map<
  string,
  { overview: typeof all[number] | null; stages: Stage[]; latest: number }
>();

for (const entry of all) {
  const [topic, stage] = entry.slug.split('/');
  if (!topic) continue;
  if (!topicMap.has(topic)) topicMap.set(topic, { overview: null, stages: [], latest: 0 });
  const bucket = topicMap.get(topic)!;
  bucket.latest = Math.max(bucket.latest, entry.data.date.valueOf());
  if (stage === 'overview') {
    bucket.overview = entry;
  } else if (stage) {
    bucket.stages.push({
      id: stage,
      label: stageLabel[stage] ?? stage,
      status: entry.data.status,
    });
  }
}

const activeTopics: ActiveTopic[] = Array.from(topicMap.entries())
  .map(([slug, t]): ActiveTopic => {
    const stages = stageOrder.map(id =>
      t.stages.find(s => s.id === id) ?? { id, label: stageLabel[id], status: 'planned' }
    );
    const done = stages.filter(s => s.status === 'complete').length;
    const active = stages.some(s => s.status === 'in-progress' || s.status === 'complete');
    return {
      slug,
      title: t.overview?.data.title ?? slug,
      desc: t.overview?.data.description ?? '',
      stages,
      done,
      active,
      latestDate: t.latest,
    };
  })
  .filter(t => t.active)
  .sort((a, b) => b.latestDate - a.latestDate);

// Planned topic registry — drawn from prompts.md.
// Each topic spins up its own folder pair (src/content/ai_research/<slug>, stage_outputs/<slug>) when work begins.
const plannedTopics: Array<{ title: string; desc: string }> = [
  {
    title: 'Philosophy → Personal Decisions',
    desc: 'How implicit positions on free will, ethics, knowledge, and identity silently shape career, relationship, risk, and meaning decisions.',
  },
  {
    title: 'Philosophy → Human Organizations',
    desc: 'How foundational assumptions about knowledge, ethics, and human nature shape the structure and failure modes of families, companies, and governments.',
  },
  {
    title: 'Philosophy of Mind',
    desc: 'Major positions on consciousness, personal identity, mental causation, and the mind–body problem — and the dependency structure between them.',
  },
  {
    title: 'Philosophy of Ethics',
    desc: 'The major ethical frameworks — internal logic, where they actually disagree vs. converge, and what each recommends in concrete situations.',
  },
  {
    title: 'Philosophy of Epistemology',
    desc: 'How we know what we know and how we should update beliefs. Major positions and what each implies for thinking, arguing, and changing your mind.',
  },
  {
    title: 'Evolution–Modernity Mismatch',
    desc: 'The gap between the environment human psychology evolved for and the one it now operates in — which mismatches cause the most suffering and what actually addresses them.',
  },
  {
    title: 'Navigating an AI World',
    desc: 'Structural analysis of how the AI transition restructures work, relationships, and meaning — beyond surface-level career advice.',
  },
  {
    title: 'Emotions: Origin, Function, Architecture',
    desc: 'What emotions are, where they come from, and what they’re for. Major theories and what each implies about regulation and self-understanding.',
  },
  {
    title: 'Meaning, Spirituality, Existential Orientation',
    desc: 'How humans construct meaning and orient toward existence — across religious, philosophical, and secular frameworks.',
  },
  {
    title: 'Bedrock Generating Functions Across Domains',
    desc: 'Five frameworks (evolution, thermodynamics, information theory, game theory, complex systems) and the structural isomorphisms they generate.',
  },
  {
    title: 'AI Decompression Framework',
    desc: 'AI relaxes bandwidth constraints that historically forced lossy compressions — money, governance, credentialing — into stable categories. What happens when those decompress.',
  },
  {
    title: 'Information Fidelity / Semantic Compression',
    desc: 'How much meaning survives transmission across channels and timescales. The loss function for communication and what it implies for institutions.',
  },
  {
    title: 'Trust Architecture',
    desc: 'How trust is built, maintained, and destroyed at every scale — and how the trust landscape has shifted from past eras.',
  },
  {
    title: 'Parent-to-Child Transmission',
    desc: 'How parents shape their children — genes, environment, parenting style, worldview transmission, and the recursion across generations.',
  },
  {
    title: 'Technology Utilization Architecture',
    desc: 'Optimal workflow architecture for an individual knowledge worker given the current AI/agent/automation toolset.',
  },
  {
    title: 'Prediction and Calibration',
    desc: 'What determines how well-calibrated someone is on a domain, and what interventions actually improve calibration.',
  },
  {
    title: 'AI Cognitive Profile',
    desc: 'Map the orthogonal cognitive dimensions where AI and human capability diverge, using O*NET tasks as the empirical substrate.',
  },
];

const groups = [
  { l: 'In Progress', items: activeTopics, planned: false },
  { l: 'Planned', items: plannedTopics, planned: true },
].filter(g => g.items.length > 0);
---

<BaseLayout title="AI’s Research — Teddy Wright"
  description="Outputs of the LLM Iterate pipeline — topics refined across five stages. Every stage has a writeup plus a possible artifact; every finished topic ends in a final writeup and artifact(s) anyone can use.">
  <section class="max-w-[760px] mx-auto px-8 pt-14 pb-24">
    <h1 class="font-display font-semibold text-[48px] leading-none m-0 mb-3 text-ink"
        style="letter-spacing: -0.03em">AI’s Research</h1>
    <p class="font-serif text-[17px] text-muted leading-[1.55] max-w-[580px] m-0 mb-14">
      A pipeline where I set AI loose on topics I choose. Five main stages — lit review, topology, model, data, build. Every stage produces a writeup plus a possible artifact, and every finished topic ends in a final writeup and artifact(s) (tool, dashboard, explainer) that any person can use.
    </p>

    <DownloadMd href="/ai-research.md" label="download all AI's research (.md)" />

    {groups.length === 0 ? (
      <div class="text-center py-16 font-serif italic text-muted">
        <p>No topics yet.</p>
      </div>
    ) : (
      groups.map(g => (
        <section class="mb-14">
          <GroupHeader label={g.l} count={g.items.length} />
          {g.planned ? (
            (g.items as typeof plannedTopics).map((t, i) => (
              <article class:list={[
                'py-5 opacity-70',
                i < g.items.length - 1 ? 'border-b border-rule-soft' : '',
              ]}>
                <h3 class="font-display font-semibold text-[20px] m-0 mb-1.5 text-ink"
                    style="letter-spacing: -0.015em">{t.title}</h3>
                <p class="font-serif text-[15px] text-ink-soft leading-[1.55] m-0"
                   style="text-wrap: pretty">{t.desc}</p>
                <div class="mt-2 font-mono text-[11px] text-muted flex gap-3 flex-wrap"
                     style="letter-spacing: 0.06em">
                  <span>writeup —</span>
                  <span>artifact —</span>
                </div>
              </article>
            ))
          ) : (
            (g.items as ActiveTopic[]).map((t, i) => {
              const hasWriteup = t.stages.find(s => s.id === 'writeup' && (s.status === 'complete' || s.status === 'in-progress'));
              const hasBuild = t.stages.find(s => s.id === 'build' && (s.status === 'complete' || s.status === 'in-progress'));
              return (
                <article class:list={[
                  'py-5',
                  i < g.items.length - 1 ? 'border-b border-rule-soft' : '',
                ]}>
                  <div class="flex items-baseline gap-3 mb-2">
                    <h3 class="font-display font-semibold text-[22px] m-0 text-ink flex-1"
                        style="letter-spacing: -0.015em">
                      <a href={`/ai-research/${t.slug}`}
                         class="text-ink no-underline hover:text-accent transition-colors">
                        {t.title}
                      </a>
                    </h3>
                    <span class="font-mono text-[11px] text-muted">{t.done}/{t.stages.length}</span>
                  </div>
                  {t.desc && (
                    <p class="font-serif text-[15px] text-ink-soft leading-[1.55] m-0 mb-3"
                       style="text-wrap: pretty">{t.desc}</p>
                  )}
                  <div class="flex gap-1 h-1.5 rounded-[3px] overflow-hidden mb-2">
                    {t.stages.map(s => {
                      const hasDraft = s.status === 'complete' || s.status === 'in-progress';
                      return (
                        <div class:list={['flex-1', hasDraft ? 'bg-accent' : 'bg-rule']} />
                      );
                    })}
                  </div>
                  <div class="font-mono text-[11px] text-muted flex gap-2.5 flex-wrap mb-3"
                       style="letter-spacing: 0.06em">
                    {t.stages.map(s => {
                      const hasDraft = s.status === 'complete' || s.status === 'in-progress';
                      return (
                        <span class:list={[hasDraft ? 'text-ink' : 'text-muted']}>{s.label}</span>
                      );
                    })}
                  </div>
                  <div class="font-mono text-[11px] flex gap-4 flex-wrap"
                       style="letter-spacing: 0.06em">
                    {hasWriteup ? (
                      <a href={`/ai-research/${t.slug}/writeup`}
                         class="text-accent no-underline hover:underline">writeup →</a>
                    ) : (
                      <span class="text-muted">writeup —</span>
                    )}
                    {hasBuild ? (
                      <a href={`/ai-research/${t.slug}/build`}
                         class="text-accent no-underline hover:underline">artifact →</a>
                    ) : (
                      <span class="text-muted">artifact —</span>
                    )}
                  </div>
                </article>
              );
            })
          )}
        </section>
      ))
    )}
  </section>
</BaseLayout>
