---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GroupHeader from '../../components/GroupHeader.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('ai_research');

const stageOrder = ['lit-review', 'topology', 'model', 'data', 'build'] as const;
const stageLabel: Record<string, string> = {
  'lit-review': 'lit review',
  topology: 'topology',
  model: 'model',
  data: 'data',
  build: 'build',
};

type Stage = { id: string; label: string; status: string };
type Topic = {
  slug: string;
  title: string;
  desc: string;
  stages: Stage[];
  done: number;
  active: boolean;
  latestDate: number;
};

const topicMap = new Map<
  string,
  { overview: typeof all[number] | null; stages: Stage[]; latest: number }
>();

for (const entry of all) {
  const [topic, stage] = entry.slug.split('/');
  if (!topic) continue;
  if (!topicMap.has(topic)) topicMap.set(topic, { overview: null, stages: [], latest: 0 });
  const bucket = topicMap.get(topic)!;
  bucket.latest = Math.max(bucket.latest, entry.data.date.valueOf());
  if (stage === 'overview') {
    bucket.overview = entry;
  } else if (stage) {
    bucket.stages.push({
      id: stage,
      label: stageLabel[stage] ?? stage,
      status: entry.data.status,
    });
  }
}

const topics: Topic[] = Array.from(topicMap.entries())
  .map(([slug, t]): Topic => {
    const stages = stageOrder.map(id =>
      t.stages.find(s => s.id === id) ?? { id, label: stageLabel[id], status: 'planned' }
    );
    const done = stages.filter(s => s.status === 'complete').length;
    const active = stages.some(s => s.status === 'in-progress' || s.status === 'complete');
    return {
      slug,
      title: t.overview?.data.title ?? slug,
      desc: t.overview?.data.description ?? '',
      stages,
      done,
      active,
      latestDate: t.latest,
    };
  })
  .sort((a, b) => b.latestDate - a.latestDate);

const groups = [
  { l: 'In Progress', items: topics.filter(t => t.active) },
  { l: 'Planned', items: topics.filter(t => !t.active) },
].filter(g => g.items.length > 0);
---

<BaseLayout title="AI’s Research — Teddy Wright"
  description="Outputs of the LLM Iterate pipeline — topics progressively refined across five stages.">
  <section class="max-w-[760px] mx-auto px-8 pt-14 pb-24">
    <h1 class="font-display font-semibold text-[48px] leading-none m-0 mb-3 text-ink"
        style="letter-spacing: -0.03em">AI’s Research</h1>
    <p class="font-serif text-[17px] text-muted leading-[1.55] max-w-[580px] m-0 mb-3">
      Outputs of the LLM Iterate pipeline. I supply a topic; AI produces a draft; we refine across five stages — lit review, topology, model, data, build.
    </p>
    <p class="font-serif italic text-[14px] text-muted m-0 mb-14">
      Each topic is one page; stages live behind tabs.
    </p>

    {topics.length === 0 ? (
      <div class="text-center py-16 font-serif italic text-muted">
        <p>No topics yet.</p>
      </div>
    ) : (
      groups.map(g => (
        <section class="mb-14">
          <GroupHeader label={g.l} count={g.items.length} />
          {g.items.map((t, i) => (
            <article class:list={[
              'py-5',
              i < g.items.length - 1 ? 'border-b border-rule-soft' : '',
            ]}>
              <div class="flex items-baseline gap-3 mb-2">
                <h3 class="font-display font-semibold text-[22px] m-0 text-ink flex-1"
                    style="letter-spacing: -0.015em">
                  <a href={`/ai-research/${t.slug}`}
                     class="text-ink no-underline hover:text-accent transition-colors">
                    {t.title}
                  </a>
                </h3>
                <span class="font-mono text-[11px] text-muted">{t.done}/{t.stages.length}</span>
              </div>
              {t.desc && (
                <p class="font-serif text-[15px] text-ink-soft leading-[1.55] m-0 mb-3"
                   style="text-wrap: pretty">{t.desc}</p>
              )}
              <div class="flex gap-1 h-1.5 rounded-[3px] overflow-hidden mb-2">
                {t.stages.map(s => (
                  <div class:list={[
                    'flex-1',
                    s.status === 'complete' ? 'bg-accent'
                      : s.status === 'in-progress' ? 'bg-accent-soft'
                      : 'bg-rule',
                  ]} />
                ))}
              </div>
              <div class="font-mono text-[11px] text-muted flex gap-2.5 flex-wrap"
                   style="letter-spacing: 0.06em">
                {t.stages.map(s => (
                  <span class:list={[
                    s.status === 'complete' ? 'text-ink'
                      : s.status === 'in-progress' ? 'text-accent'
                      : 'text-muted',
                  ]}>{s.label}</span>
                ))}
              </div>
            </article>
          ))}
        </section>
      ))
    )}
  </section>
</BaseLayout>
