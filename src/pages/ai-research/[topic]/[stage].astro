---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import RefinementLog from '../../../components/RefinementLog.astro';
import DownloadMd from '../../../components/DownloadMd.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('ai_research');
  return all
    .filter(entry => entry.slug.includes('/'))
    .map(entry => {
      const [topic, stage] = entry.slug.split('/');
      return {
        params: { topic, stage },
        props: { entry },
      };
    });
}

const { entry } = Astro.props;
const { topic, stage } = Astro.params;
const { Content } = await entry.render();

const stageLabel: Record<string, string> = {
  'lit-review': 'Lit Review',
  topology: 'Topology',
  model: 'Model',
  data: 'Data',
  build: 'Build',
  writeup: 'Writeup',
  overview: 'Overview',
};
---

<BaseLayout title={`${entry.data.title} — ${topic}`} description={entry.data.description}>
  <article class="max-w-[760px] mx-auto px-8 pt-14 pb-24">
    <div class="flex items-center justify-between gap-4 flex-wrap">
      <a href={`/ai-research/${topic}`}
         class="font-mono text-[11px] uppercase text-muted no-underline hover:text-accent transition-colors"
         style="letter-spacing: 0.08em">← {topic}</a>
      <DownloadMd href={`/ai-research/${topic}/${stage}.md`} label="download stage (.md)" align="right" />
    </div>

    <header class="mt-5 mb-10 pb-8 border-b border-rule">
      <div class="flex items-baseline gap-3 mb-3 flex-wrap">
        <span class="font-mono text-[10px] uppercase text-accent"
              style="letter-spacing: 0.12em">{stageLabel[stage ?? ''] ?? stage}</span>
        <span class:list={[
          'font-mono text-[11px]',
          entry.data.status === 'complete' ? 'text-ink'
            : entry.data.status === 'in-progress' ? 'text-accent'
            : 'text-muted',
        ]} style="letter-spacing: 0.06em">{entry.data.status}</span>
        {entry.data.refinementPass > 0 && (
          <span class="font-mono text-[11px] text-muted">pass {entry.data.refinementPass}</span>
        )}
      </div>
      <h1 class="font-display font-semibold text-[36px] leading-[1.1] m-0 mb-3 text-ink"
          style="letter-spacing: -0.02em; text-wrap: balance">{entry.data.title}</h1>
      <p class="font-serif text-[17px] text-ink-soft leading-[1.55] m-0"
         style="text-wrap: pretty">{entry.data.description}</p>
    </header>

    <div class="paper-prose">
      <Content />
    </div>

    {entry.data.refinementLog.length > 0 && (
      <RefinementLog log={entry.data.refinementLog} />
    )}
  </article>
</BaseLayout>
