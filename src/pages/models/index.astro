---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const models = (await getCollection('models', ({ data }) => data.status === 'published'))
  .sort((a, b) =>
    Number(b.data.featured) - Number(a.data.featured)
    || b.data.date.valueOf() - a.data.date.valueOf()
  );
---

<BaseLayout title="Models — Teddy Wright" description="Interactive quantitative models — formalizations of relational, emotional, and decision-theoretic problems.">
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-16">
    <h1 class="text-3xl font-bold tracking-tight mb-4">Models</h1>
    <p class="text-gray-500 mb-12">
      Interactive quantitative models — formalizations of relational, emotional,
      and decision-theoretic problems. Slide the inputs and watch the output move.
    </p>

    {models.length === 0 ? (
      <div class="text-center py-16 text-gray-400">
        <p class="text-sm">No models published yet.</p>
      </div>
    ) : (
      <div class="space-y-8">
        {models.map(({ slug, data }) => (
          <article class="border-l-2 border-primary-200 pl-4">
            <h2 class="text-lg font-semibold">
              <a href={`/models/${slug}`} class="hover:text-primary-600 transition-colors">
                {data.title}
              </a>
            </h2>
            <p class="text-sm text-gray-500 mt-2">{data.description}</p>
            {data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-3">
                {data.tags.map(tag => (
                  <span class="text-xs text-gray-400">{tag}</span>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
